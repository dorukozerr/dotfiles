{
  "eslint.alwaysShowStatus": true,
  "eslint.useFlatConfig": true,
  "floatFactory.floatConfig": {
    "border": false,
    "rounded": false,
    "borderhighlight": "CocFloatingBorder"
  },
  "suggest.floatConfig": {
    "border": false,
    "rounded": false,
    "borderhighlight": "CocFloatingBorder",
    "highlight": "CocFloating"
  },
  "tsserver.experimental.enableProjectDiagnostics": true,
  "diagnostic.floatConfig": {
    "borderhighlight": "CocFloatingBorder",
    "highlight": "CocFloating"
  },
  "oxc.oxfmt.enable": true,
  "javascript.format.enable": false,
  "typescript.format.enable": false,
  "prettier.enable": false,
  "coc.preferences.formatOnSave": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "snippets.trace": "error",
  "snippet.highlight": true,
  "snippets.ultisnips.trace": true,
  "snippets.extends": {
    "typescriptreact": [
      "typescript"
    ],
    "javascriptreact": [
      "javascript"
    ]
  }
}
